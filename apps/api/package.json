    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.0",
    "@prisma/client": "^5.14.0",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
